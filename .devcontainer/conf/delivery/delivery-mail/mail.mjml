          <mj-social-element name="linkedin" href="https://www.linkedin.com/groups/4164805/"></mj-social-element>
          <mj-social-element name="github" src="https://www.mailjet.com/images/theme/v1/icons/ico-social/github.png"
            background-color="#333" href="https://github.com/Alinto/sogo/"></mj-social-element>
        </mj-social>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
